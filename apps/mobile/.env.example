EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Hostname only — must match NEXT_PUBLIC_SITE_URL on the web app (universal / app links).
# Example: del.saharshams.com or app.example.com
EXPO_PUBLIC_WEB_APP_HOST=del.saharshams.com

# EAS build-only file env for Android push registration with FCM.
# Create this as a file variable in the EAS environment; do not paste JSON here.
# GOOGLE_SERVICES_JSON=/path/to/google-services.json
