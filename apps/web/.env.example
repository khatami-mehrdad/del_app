NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only. Keep this in GitHub/Vercel secrets, never in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical HTTPS origin used in invite links and post-deploy smoke checks.
NEXT_PUBLIC_SITE_URL=https://del.saharshams.com

# Universal / app links served from apps/web/app/.well-known/*
APPLE_APP_SITE_ASSOCIATION_APP_IDS=YOURTEAMID.com.saharshams.del
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:EE:FF

# Pre-release APK download URL shown on the client invite page.
# Replace with Play Store link once published.
NEXT_PUBLIC_APK_DOWNLOAD_URL=https://github.com/khatami-mehrdad/del_app/releases/download/preview-android-latest/del-preview-android-latest.apk

# Public contact for account deletion page (https://your-domain/delete-account)
NEXT_PUBLIC_ACCOUNT_DELETION_EMAIL=you@example.com
